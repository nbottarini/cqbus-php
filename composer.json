{
    "name": "botta/cqbus",
    "description": "Simple command/query bus for modern PHP applications",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "pestphp/pest": "^4.7.3"
    },
    "autoload": {
        "psr-4": {
            "Botta\\CQBus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Botta\\CQBus\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
